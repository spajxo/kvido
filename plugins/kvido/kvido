#!/usr/bin/env bash
# =============================================================================
# kvido — CLI for kvido assistant plugin
# =============================================================================
# Combined launcher + script dispatcher. Resolves plugin install path from
# the Claude Code plugin registry. Designed to be symlinked to ~/.local/bin/kvido.
#
# Usage:
#   kvido                                     # launch Claude with heartbeat loop
#   kvido /kvido:morning                      # launch Claude with custom prompt
#   kvido task list todo                      # shortcut for skills/worker/task.sh
#   kvido heartbeat-state set key value       # shortcut for skills/heartbeat/heartbeat-state.sh
#   kvido config 'sources.gitlab.repos'       # shortcut for skills/config.sh
#   kvido --root                              # print plugin root path
#   kvido --install                           # symlink to ~/.local/bin/kvido
#
# Routing:
#   --root / --install    → built-in commands
#   skills/* / agents/*   → direct dispatch (backward compat)
#   <name> [args]         → auto-resolve script by name from skills/
#   everything else       → Claude launcher
# =============================================================================

set -euo pipefail

_resolve_root() {
  # 1. If running from plugin dir, use SCRIPT_DIR
  local script_dir
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  if [[ -f "$script_dir/.claude-plugin/plugin.json" ]]; then
    echo "$script_dir"
    return
  fi

  # 2. Resolve from registry
  local registry="$HOME/.claude/plugins/installed_plugins.json"
  if [[ ! -f "$registry" ]]; then
    echo "ERROR: Plugin registry not found: $registry" >&2
    exit 1
  fi

  local root
  root=$(jq -r '
    .plugins | to_entries[]
    | select(.key | startswith("kvido@"))
    | .value[0].installPath
  ' "$registry" 2>/dev/null | head -1)

  if [[ -z "$root" || "$root" == "null" || ! -d "$root" ]]; then
    echo "ERROR: kvido plugin not found in registry" >&2
    exit 1
  fi
  echo "$root"
}

KVIDO_ROOT="$(_resolve_root)"

case "${1:-}" in
  --root)
    echo "$KVIDO_ROOT"
    ;;
  --install)
    mkdir -p "$HOME/.local/bin"
    # Write a wrapper that resolves plugin path from registry at runtime.
    # A symlink would go stale when the plugin version changes in cache.
    cat > "$HOME/.local/bin/kvido" <<'WRAPPER'
#!/usr/bin/env bash
_P=$(jq -r '.plugins | to_entries[] | select(.key | startswith("kvido@")) | .value[0].installPath' "$HOME/.claude/plugins/installed_plugins.json" 2>/dev/null | head -1)
if [[ -z "$_P" || "$_P" == "null" || ! -d "$_P" ]]; then
  echo "ERROR: kvido plugin not found in registry" >&2; exit 1
fi
exec "$_P/kvido" "$@"
WRAPPER
    chmod +x "$HOME/.local/bin/kvido"
    echo "Installed: ~/.local/bin/kvido (registry-based wrapper)"
    ;;
  skills/*|agents/*)
    # Script dispatch — resolve to plugin install path
    TARGET="$KVIDO_ROOT/$1"
    shift
    if [[ ! -f "$TARGET" ]]; then
      echo "ERROR: Script not found: $TARGET" >&2
      exit 1
    fi
    exec bash "$TARGET" "$@"
    ;;
  *)
    # Try auto-resolve as short command name → skills/*.sh
    _RESOLVED=""
    if [[ -n "${1:-}" ]]; then
      _NAME="${1%.sh}"
      if [[ -f "$KVIDO_ROOT/skills/$_NAME.sh" ]]; then
        _RESOLVED="$KVIDO_ROOT/skills/$_NAME.sh"
      elif [[ -f "$KVIDO_ROOT/skills/$_NAME/$_NAME.sh" ]]; then
        _RESOLVED="$KVIDO_ROOT/skills/$_NAME/$_NAME.sh"
      else
        _MATCH=$(find "$KVIDO_ROOT/skills" -name "$_NAME.sh" -type f 2>/dev/null | head -1)
        [[ -n "$_MATCH" ]] && _RESOLVED="$_MATCH"
      fi
    fi

    if [[ -n "$_RESOLVED" ]]; then
      shift
      exec bash "$_RESOLVED" "$@"
    fi

    # Claude launcher — official env vars (ANTHROPIC_*, CLAUDE_CODE_*) are
    # read automatically by Claude Code. Only KVIDO_* vars map to CLI flags
    # that have no env var equivalent.
    if [[ -f .env ]]; then
      set -a; source .env; set +a
    fi

    PROMPT="${*:-/loop 5m /kvido:heartbeat}"

    ARGS=(
      --name "${KVIDO_NAME:-kvido}"
      --permission-mode "${KVIDO_PERMISSION_MODE:-default}"
    )

    if [[ -n "${KVIDO_EXTRA_ARGS:-}" ]]; then
      # shellcheck disable=SC2086
      ARGS+=($KVIDO_EXTRA_ARGS)
    fi

    exec claude "${ARGS[@]}" "$PROMPT"
    ;;
esac
