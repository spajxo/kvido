---
# =============================================================================
# kvido.local.md — Kvido assistant configuration
# =============================================================================
# Copy to .claude/kvido.local.md in your project and fill in your data.
# Usage: skills/config.sh 'key' [default]
# Usage: skills/config.sh --keys 'prefix'
# Example: skills/config.sh 'sources.gmail.max_results'
# Example: skills/config.sh --keys 'sources.gitlab.repos'
#
# Format: flat dot-notation keys. No nesting. Arrays use named sub-keys.
# =============================================================================

# =============================================================================
# SOURCES — data sources
# =============================================================================

# Jira ---
sources.jira.tool.primary: acli
sources.jira.tool.fallback: atlassian-mcp
# sources.jira.projects.PROJ.filter: "assignee = currentUser() AND status != Done ORDER BY updated DESC"
# sources.jira.projects.PROJ.label: My Project

# GitLab ---
# sources.gitlab.repos.group-project.path: ~/Projects/path/to/repo
# sources.gitlab.repos.group-project.branches: main
# sources.gitlab.repos.group-project.priority: high
# sources.gitlab.repos.group-kb.path: ~/Projects/path/to/kb
# sources.gitlab.repos.group-kb.priority: low
# sources.gitlab.repos.group-kb.type: knowledge-base

# Slack ---
sources.slack.self_dm_channel.name: assistant
sources.slack.self_dm_channel.channel_id: ""
# sources.slack.dm_channels.person-name.user_id: UXXXXXXXXXX
# sources.slack.dm_channels.person-name.channel_id: DXXXXXXXXXX
# sources.slack.dm_channels.person-name.priority: normal
# sources.slack.channels.channel-name.channel_id: CXXXXXXXXXX
# sources.slack.channels.channel-name.priority: high

# Calendar ---
sources.calendar.categories.standup: standup,daily
sources.calendar.categories.planning: planning,refinement,grooming
sources.calendar.categories.one_on_one: "1:1,1on1"
sources.calendar.categories.focus: "focus,deep work"
sources.calendar.default_category: meeting

# Gmail ---
sources.gmail.watch_query: "is:unread -category:promotions -category:social"
sources.gmail.max_results: 20
# sources.gmail.priority_senders: "*@example.com"
# sources.gmail.labels_ignore: CATEGORY_PROMOTIONS,CATEGORY_SOCIAL

# Sessions ---
sources.sessions.idle_threshold_min: 10
sources.sessions.default_date: yesterday

# =============================================================================
# SKILLS — behavior and feature configuration
# =============================================================================

# Heartbeat ---
skills.heartbeat.presets.5m: "*/5 * * * *"
skills.heartbeat.presets.10m: "*/10 * * * *"
skills.heartbeat.presets.30m: "*/30 * * * *"
skills.heartbeat.presets.60m: "3 * * * *"
skills.heartbeat.wh_start: 7
skills.heartbeat.wh_end: 16
skills.heartbeat.wh_min_interval: 10m
skills.heartbeat.wh_after_interaction: 5m
skills.heartbeat.wh_interaction_window_minutes: 30
skills.heartbeat.decay.30.preset: 5m
skills.heartbeat.decay.120.preset: 10m
skills.heartbeat.decay.240.preset: 30m
skills.heartbeat.decay.null.preset: 60m

# Planner ---
skills.planner.planning_interval: 10

# Worker ---
skills.worker.work_dir: state/work
skills.worker.max_concurrent: 2
skills.worker.task_timeout_minutes: 8
skills.worker.stale_lock_minutes: 10
skills.worker.overflow_threshold: 20
skills.worker.models.s: claude-sonnet-4-6
skills.worker.models.m: claude-sonnet-4-6
skills.worker.models.l: claude-opus-4-6
skills.worker.models.xl: claude-opus-4-6
skills.worker.urgent_model: claude-opus-4-6

# Slack behavior ---
skills.slack.batching.enabled: true
skills.slack.batching.window: full_heartbeat

# Triage ---
skills.triage.wip_limit: 3
skills.triage.triage_overflow_threshold: 10
skills.triage.done_rotation: friday

# Dashboard ---
skills.dashboard.enabled: true
skills.dashboard.auto_refresh: 20

# Daily Questions ---
skills.daily_questions.enabled: true
skills.daily_questions.max_questions: 2
skills.daily_questions.frequency: weekdays

# Interests ---
# skills.interests.topics.example-topic.name: "Example topic"
# skills.interests.topics.example-topic.query: "example search query"
# skills.interests.topics.example-topic.urgency: medium
# skills.interests.topics.example-topic.check_interval: weekly
# skills.interests.topics.example-topic.reason: "Why this matters"
---

# Custom instructions

<!-- Optional markdown body for per-project notes or overrides. -->
