#!/usr/bin/env bash
# =============================================================================
# kvido — entry point shim (plugin root level)
# =============================================================================
# CC v2.1.91+ adds plugin's bin/ to PATH automatically, so within a CC session
# bin/kvido is found directly. This shim exists for backward compatibility when
# invoked from outside CC (e.g. direct path exec or registry-based wrappers).
#
# All logic lives in bin/kvido. No path discovery here — root is simply the
# directory this script lives in.
# =============================================================================

set -euo pipefail

KVIDO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
exec "$KVIDO_ROOT/bin/kvido" "$@"
